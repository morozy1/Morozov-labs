% Слайд 2: Основание
\begin{frame}{Основание факультета}
    \begin{itemize}
        \item \textbf{5 августа 1931 г.} — СНК РСФСР распорядился создать в Орле индустриально-педагогический институт
        \item \textbf{16 октября 1931 г.} — первые 121 студент и 11 преподавателей начали занятия
        \item \textbf{1932 г.} — физико-технический факультет преобразован в \textbf{физико-математический}
        \item \textbf{Июнь 1935 г.} — первый выпуск: 45 специалистов (26 математиков)
    \end{itemize}
\end{frame}

